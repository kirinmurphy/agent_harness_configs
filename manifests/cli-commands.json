{
  "usage": [
    "roborepo                       interactive menu",
    "",
    "roborepo skill new [--kind=auto|skill-command|standalone] [--name=<name>] [--description=<text>]",
    "roborepo skill export-to-local [--yes] [--on-conflict=skip|override]",
    "roborepo skill symlink-local   [--dry-run] [--uninstall]",
    "roborepo skill symlink-global  [--check]",
    "roborepo skill commands [--check]                   render/check slash commands",
    "",
    "roborepo index code  [path]",
    "roborepo index docs  [path]",
    "roborepo mcp add <name-or-url> [--scope=user|local|project] [--name=<name>] [--dry-run] [--only-claude|--only-codex] [--skip-claude-permission]",
    "roborepo watch code  [path]",
    "",
    "roborepo run <cmd> [args...]",
    "",
    "roborepo update  [--dry-run] [--mode managed|adopt] [--on-conflict overwrite|keep|agent]",
    "roborepo uninstall [--dry-run]",
    "roborepo backfill              pull live config back into the repo",
    "roborepo doctor  [--installed] health check",
    "roborepo verify                post-install verification",
    "roborepo rules   [--check]     render/check generated agent rules",
    "roborepo permissions [--check] [--profile <name>] render/check agent permission outputs",
    "",
    "roborepo --help | -h",
    "",
    "[path] is optional (defaults to the current directory) and may be relative or absolute."
  ],
  "menu": [
    { "header": "Setup" },
    { "label": "update", "value": ["update"], "desc": "re-apply harness config on this machine (pick up new config)" },
    { "label": "uninstall", "value": ["uninstall"], "desc": "remove repo-owned symlinks and install state" },
    { "header": "Day to day" },
    { "label": "index code", "value": ["index", "code"], "desc": "index this repo's code for jcodemunch" },
    { "label": "index docs", "value": ["index", "docs"], "desc": "index this repo's docs for jdocmunch" },
    { "label": "mcp add", "value": ["mcp", "add"], "desc": "register an MCP server with Claude + Codex" },
    { "label": "watch code", "value": ["watch", "code"], "desc": "live-index code as files change" },
    { "label": "run", "value": ["run"], "desc": "run a command with trimmed output" },
    { "header": "Skills" },
    { "label": "skill new", "value": ["skill", "new"], "desc": "scaffold a shared skill or slash command" },
    { "label": "skill export-to-local", "value": ["skill", "export-to-local"], "desc": "copy shared skills into this repo" },
    { "label": "skill symlink-local", "value": ["skill", "symlink-local"], "desc": "symlink .agents/skills into .claude/.codex" },
    { "label": "skill symlink-global", "value": ["skill", "symlink-global"], "desc": "symlink shared skill source into global harness folders" },
    { "label": "skill commands", "value": ["skill", "commands"], "desc": "render slash commands" },
    { "header": "Maintenance" },
    { "label": "backfill", "value": ["backfill"], "desc": "pull live config back into the repo" },
    { "label": "doctor", "value": ["doctor"], "desc": "health check" },
    { "label": "verify", "value": ["verify"], "desc": "post-install verification" },
    { "label": "rules", "value": ["rules"], "desc": "render/check generated agent rules" },
    { "label": "permissions", "value": ["permissions"], "desc": "render/check agent permission outputs" },
    { "header": "Other" },
    { "label": "help", "value": ["--help"], "desc": "show full usage" },
    { "label": "exit", "value": null, "desc": "quit" }
  ],
  "repoScripts": {
    "skill symlink-global": { "runtime": "bash", "path": "scripts/build/link-skills.sh" },
    "skill commands": { "runtime": "node", "path": "scripts/build/render-slash-commands.mjs" },
    "update": { "runtime": "bash", "path": "scripts/install/main.sh" },
    "uninstall": { "runtime": "bash", "path": "scripts/install/uninstall.sh" },
    "backfill": { "runtime": "bash", "path": "scripts/sync-from-home.sh" },
    "doctor": { "runtime": "bash", "path": "scripts/doctor.sh" },
    "verify": { "runtime": "bash", "path": "scripts/verify-install.sh" },
    "rules": { "runtime": "bash", "path": "scripts/build/render-rules.sh" },
    "permissions": { "runtime": "node", "path": "scripts/build/render-agent-permissions.mjs" }
  }
}

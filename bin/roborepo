#!/usr/bin/env bash
set -euo pipefail

# Resolve this script's real location (symlinked into ~/.local/bin), then exec the Node
# implementation in the repo. roborepo subcommands operate on the CURRENT working dir, so
# exec preserves cwd. Works from any cwd, on macOS/Linux/Git Bash.
source_path="${BASH_SOURCE[0]}"
while [[ -L "${source_path}" ]]; do
  dir="$(cd "$(dirname "${source_path}")" && pwd)"
  source_path="$(readlink "${source_path}")"
  [[ "${source_path}" != /* ]] && source_path="${dir}/${source_path}"
done
bin_dir="$(cd "$(dirname "${source_path}")" && pwd)"
repo_root="$(cd "${bin_dir}/.." && pwd)"

if ! command -v node >/dev/null 2>&1; then
  echo "roborepo requires Node.js (node not found on PATH)." >&2
  exit 1
fi

exec node "${repo_root}/scripts/cli/main.mjs" "$@"

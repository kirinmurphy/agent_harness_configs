prefix_rule(pattern=["git", "push"], decision="forbidden")
prefix_rule(pattern=["git", "pull"], decision="forbidden")
prefix_rule(pattern=["git", "rm"], decision="forbidden")
prefix_rule(pattern=["rm"], decision="forbidden")
prefix_rule(pattern=["npx", "playwright", "test"], decision="allow")
prefix_rule(pattern=["npm", "test"], decision="allow")
prefix_rule(pattern=["npm", "run", "test"], decision="allow")
prefix_rule(pattern=["pnpm", "test"], decision="allow")
prefix_rule(pattern=["pnpm", "run", "test"], decision="allow")

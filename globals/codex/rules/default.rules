prefix_rule(pattern=["./scripts/verify-install.sh"], decision="allow")
prefix_rule(pattern=["./scripts/install/main.sh", "--dry-run"], decision="allow")
prefix_rule(pattern=["roborepo", "doctor"], decision="allow")
prefix_rule(pattern=["roborepo", "verify"], decision="allow")
prefix_rule(pattern=["roborepo", "update", "--dry-run"], decision="allow")
prefix_rule(pattern=["npm", "run", "skills:compile"], decision="allow")
prefix_rule(pattern=["npm", "run", "skills:validate"], decision="allow")
prefix_rule(pattern=["npm", "install"], decision="allow")
prefix_rule(pattern=["npm", "run", "lint"], decision="allow")
prefix_rule(pattern=["npm", "run", "build:preview"], decision="allow")
prefix_rule(pattern=["npm", "run", "build"], decision="allow")
prefix_rule(pattern=["npm", "run", "dev"], decision="allow")
prefix_rule(pattern=["npm", "run", "demo:start"], decision="allow")
prefix_rule(pattern=["npm", "run", "audit:run:blocking"], decision="allow")
prefix_rule(pattern=["npm", "run", "audit:run"], decision="allow")
prefix_rule(pattern=["npm", "run", "check"], decision="allow")
prefix_rule(pattern=["npx", "tsc"], decision="allow")
prefix_rule(pattern=["npx", "next", "lint"], decision="allow")
prefix_rule(pattern=["npx", "eslint"], decision="allow")
prefix_rule(pattern=["npx", "jest"], decision="allow")
prefix_rule(pattern=["/bin/zsh", "-lc", "npm run check > /tmp/sembrando-astro-check.log 2>&1"], decision="allow")
prefix_rule(pattern=["npx", "convex", "codegen"], decision="allow")
prefix_rule(pattern=["git", "status"], decision="allow")
prefix_rule(pattern=["git", "log"], decision="allow")

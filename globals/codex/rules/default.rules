prefix_rule(pattern=["docker", "volume", "inspect"], decision="allow")
prefix_rule(pattern=["docker", "stats", "--no-stream"], decision="allow")
prefix_rule(pattern=["docker", "builder", "prune", "-f"], decision="allow")
